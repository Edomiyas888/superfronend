# Baked into `vite build` — points the deployed app at live superbet-api on Render.
# Local dev still uses `.env` (localhost).
# Vercel: do NOT set VITE_API_URL=http://localhost:3001 — it overrides this file and breaks Telegram Mini App.

VITE_SWARM_TRANSPORT=websocket
VITE_SWARM_WS_URL=wss://eu-swarm-ws.betconstruct.com
VITE_SWARM_SOURCE=4

VITE_SWARM_API_URL=https://superbackend-zc52.onrender.com/api/
VITE_API_URL=https://superbackend-zc52.onrender.com

VITE_SWARM_HTTP_FALLBACK=false
VITE_USE_REST_SPORT_LIST=false
