# --- Swarm ---
# If superbet-api returns 502 "Cloudflare / bot-check": Swarm HTTP from Node is blocked at the edge.
# Use browser WebSocket (below) — same as finixbet. Optional: ask operator to allowlist your API server IP for HTTP.

VITE_SWARM_TRANSPORT=websocket
VITE_SWARM_WS_URL=wss://eu-swarm-ws.betconstruct.com
VITE_SWARM_API_URL=http://localhost:3001/api/

# Only if WS fails: retry HTTP via superbet-api (may 502 behind CF)
# VITE_SWARM_HTTP_FALLBACK=true

# If the API is down in dev only:
# VITE_SWARM_API_FALLBACKS=/bc-swarm/

# VITE_SWARM_SITE_ID=1
# VITE_SWARM_SOURCE=4
# VITE_SWARM_LANGUAGE=eng

VITE_USE_REST_SPORT_LIST=false

# superbet-api root (auth / wallet). Defaults from VITE_SWARM_API_URL if unset.
# VITE_API_URL=http://localhost:3001

# --- Firebase Authentication phone sign-in (Profile → Phone tab) ---
# Copy the web app config from Firebase console → Project settings → Your apps → SDK setup.
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project-id
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# Dev only: use fictional test numbers from Firebase → Authentication → Phone → test numbers
# VITE_FIREBASE_PHONE_TESTING=1

# --- Production deploy (see also `.env.production` committed for `vite build`) ---
# Live backend on Render — use the same values in your static host’s env if you don’t rely on `.env.production`.
# Ensure superbet-api `CORS_ORIGINS` includes your frontend origin (e.g. https://your-app.onrender.com).
#
# VITE_SWARM_API_URL=https://superbackend-zc52.onrender.com/api/
# VITE_API_URL=https://superbackend-zc52.onrender.com

# --- Telegram Mini App ---
# No frontend env required — auth uses Telegram WebApp initData automatically when opened inside Telegram.
# Deploy the built app to HTTPS, then in @BotFather: /mybots → your bot → Bot Settings → Menu Button → set URL.
# Add your Mini App origin to superbet-api CORS_ORIGINS (exact HTTPS origin, no trailing slash).

# --- E2E (Playwright) — optional; set when testing a deployed build instead of local dev ---
# PLAYWRIGHT_BASE_URL=https://your-staging.example.com
